PORT=3001

# --- Database (Azure PostgreSQL Flexible Server) ---
PGHOST=your-server.postgres.database.azure.com
PGUSER=your-admin-user
PGPORT=5432
PGDATABASE=postgres
PGPASSWORD=your-password

# DATABASE_URL — richiesta dai comandi prisma migrate/generate CLI.
# L'app la costruisce automaticamente dai PG* vars a runtime,
# ma per i comandi CLI va impostata esplicitamente.
# Formato: postgresql://PGUSER:PGPASSWORD@PGHOST:PGPORT/PGDATABASE?sslmode=require
DATABASE_URL=postgresql://your-admin-user:your-password@your-server.postgres.database.azure.com:5432/postgres?sslmode=require

# Microsoft Entra ID — token validation
# Tenant ID e Client ID NON necessari: il tenant viene letto dal claim `tid` del token.
# Nome del claim che contiene il ruolo (es. roles, extension_role, jobTitle)
ENTRA_ROLE_CLAIM=roles
